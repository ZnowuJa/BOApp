@page "/generalsettings"
@inject NavigationManager _navMan

<h3>ITCMDBSettings</h3>

<FluentGrid Justify="@Justification">
    <FluentGridItem xs="@xssize" sm="@smsize">
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical"
                        HorizontalAlignment="HorizontalAlignment.Center"
                        VerticalAlignment="VerticalAlignment.Center"
                        >
            <FluentIcon Value="@(new Icons.Regular.Size24.BookStar())" />
            <h4>Organisations</h4>
                
            <FluentButton BackgroundColor="var(--accent-fill-rest)"
                            Color="var(--neutral-fill-rest)"
                            OnClick="@(()=>_navMan.NavigateTo("/organisations"))">
                Organisations
            </FluentButton>
        </FluentStack>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="@xssize" sm="@smsize">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical"
                         HorizontalAlignment="HorizontalAlignment.Center"
                         VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.BookStar())" />
                <h4>Workflows</h4>

                <FluentButton BackgroundColor="var(--accent-fill-rest)"
                              Color="var(--neutral-fill-rest)"
                              OnClick="@(()=>_navMan.NavigateTo("/workflows"))">
                    Workflows
                </FluentButton>
            </FluentStack>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="@xssize" sm="@smsize">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical"
                         HorizontalAlignment="HorizontalAlignment.Center"
                         VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.BookStar())" />
                <h4>Deferral Payments</h4>

                <FluentButton BackgroundColor="var(--accent-fill-rest)"
                              Color="var(--neutral-fill-rest)"
                              OnClick="@(()=>_navMan.NavigateTo("/deferralpayments"))">
                    Deferral Payments
                </FluentButton>
            </FluentStack>
        </FluentCard>
    </FluentGridItem>
</FluentGrid>
           


@code {
    JustifyContent Justification = JustifyContent.Center;

    public int xssize { get; set; } = 2;
    public int smsize { get; set; } = 2;

    private async Task JakasFunkcja()
        {
            _navMan.NavigateTo("/itcmdbsettings");
        }
}
