@page "/bnppage"
@using System.Diagnostics.CodeAnalysis
@using Application.CQRS.AccountingCQRS.BNP.Queries
@using Application.ViewModels.Accounting
@using Microsoft.AspNetCore.Authorization
@using System.Linq.Expressions
@using System.Globalization;

@attribute [Authorize(Policy = "Technician")]

@inject IMediator _mediator
@inject IToastService _toastService

<h3>
    Wyciągi Bankowe
</h3>

<FluentTabs @bind-ActiveTabId="@activeid" OnTabChange="HandleOnTabChange">
    <FluentTab Label="BNP20" Id="tab-1">
        <div style="display: flex; gap: 16px;">
            <div>
                <FluentDatePicker DisabledDateFunc="@IsAfterEndDate" Label="Start Date" AriaLabel="Start Date" Value="StartDateTime20" ValueChanged="@(e => OnDateChanged("Start", "tab-1", e))"/>
            </div>
            <div>
                <FluentDatePicker DisabledDateFunc="@IsDateDisabled" Label="End Date" AriaLabel="End Date" Value="EndDateTime20" ValueChanged="@(e => OnDateChanged("End", "tab-1", e))"/>
            </div>
        </div>
        @if (IsLoading20)
        {
            <FluentProgressRing />
        }
        else
        {
            <div>
                <p>Data has been loaded successfully.</p>
            </div>
        }

        @if (bnp20 == null)
        {
            <FluentProgressRing>Loading...</FluentProgressRing>
        }
        else
        {
            <FluentDataGrid Items="@FilteredItems"
                            Pagination="@pagination20"
                            Virtualize="true"
                            ResizableColumns="true"
                            Style="height: 650px; overflow:auto;"
                            ShowHover="true"
                            ItemSize="55"
                            TGridItem="Bnp20Vm">

                @foreach (var column in filterColumns.Where(c => c.IsVisible))
                {
                    <PropertyColumn TGridItem="Bnp20Vm" TProp="string" Property="@(GetPropertyExpression(column.Property))" Sortable="true" Align="Align.Start" Tooltip="true" Title="@column.Label" Filtered="!string.IsNullOrWhiteSpace(column.Filter)" Width="@column.Width" IsDefaultSortColumn="@column.IsDefaultSortColumn"
                                    InitialSortDirection="@column.InitialSortDirection">
                        <ColumnOptions>
                            <div class="search-box">
                                <FluentSearch type="search" Autofocus="true" @bind-Value="column.Filter" @oninput="(args) => HandleFilterDebounced(column, args)" Placeholder="@($"{column.Label.ToLower()}...")" />
                            </div>
                        </ColumnOptions>
                    </PropertyColumn>
                }
                <PropertyColumn Property="@(c => c.Amount)" Sortable="true" Align="Align.Start" Tooltip="true" Width="200px">
                </PropertyColumn>
            </FluentDataGrid>

            <FluentPaginator State="@pagination20" />
        }
    </FluentTab>
    <FluentTab Label="BNP55" Id="tab-2">

        <div style="display: flex; gap: 16px;">
            <div>
                <FluentDatePicker Label="Start Date" AriaLabel="Start Date" Value="StartDateTime55" ValueChanged="@(e => OnDateChanged("Start", "tab-2", e))" />
            </div>
            <div>
                <FluentDatePicker Label="End Date" AriaLabel="End Date" Value="EndDateTime55" ValueChanged="@(e => OnDateChanged("End", "tab-2", e))" />
            </div>
        </div>
        @if (IsLoading55)
        {
            <FluentProgressRing />
        }
        else
        {
            <div>
                <p>Data has been loaded successfully.</p>
            </div>
        }

        @if (bnp55 == null)
        {
            <FluentProgressRing>Loading...</FluentProgressRing>
        }
        else
        {

            <FluentDataGrid Items="@FilteredItems55"
                            Pagination="@pagination55"
                            Virtualize="true"
                            ResizableColumns="true"
                            Style="height: 650px; overflow:auto;"
                            ShowHover="true"
                            ItemSize="55"
                            TGridItem="Bnp55Vm">

                @foreach (var column in filterColumns55.Where(c => c.IsVisible))
                {
                    if (column.Property != null)
                    {
                        <PropertyColumn TGridItem="Bnp55Vm" TProp="string" Property="@(GetPropertyExpression55(column.Property))" Sortable="true" Align="Align.Start" Tooltip="true" Title="@column.Label" Filtered="!string.IsNullOrWhiteSpace(column.Filter)" Width="@column.Width" IsDefaultSortColumn="@column.IsDefaultSortColumn"
                                        InitialSortDirection="@column.InitialSortDirection">
                            <ColumnOptions>
                                <div class="search-box">
                                    <FluentSearch type="search" Autofocus="true" @bind-Value="column.Filter" @oninput="(args) => HandleFilterDebounced55(column, args)" Placeholder="@($"{column.Label.ToLower()}...")" />
                                </div>
                            </ColumnOptions>
                        </PropertyColumn>
                    }
                }
                <PropertyColumn Property="@(c => c.Amount)" Sortable="true" Align="Align.Start" Tooltip="true" Width="200px">
                </PropertyColumn>
                
                </FluentDataGrid>

            <FluentPaginator State="@pagination55" />
        }
    </FluentTab>
</FluentTabs>



@code {
    private IQueryable<Bnp20Vm>? bnp20;
    private IQueryable<Bnp20Vm> FilteredItems => bnp20.Where(x =>
        filterColumns.All(column => string.IsNullOrWhiteSpace(column.Filter) || column.Property(x).Contains(column.Filter, StringComparison.CurrentCultureIgnoreCase)));
    
    private IQueryable<Bnp55Vm>? bnp55;
    private IQueryable<Bnp55Vm> FilteredItems55 => bnp55.Where(x =>
        filterColumns55.All(column => string.IsNullOrWhiteSpace(column.Filter) || column.Property(x).Contains(column.Filter, StringComparison.CurrentCultureIgnoreCase)));

    private readonly DebounceDispatcher debounceDispatcher = new DebounceDispatcher();
    
    readonly PaginationState pagination20 = new PaginationState { ItemsPerPage = 10 };
    readonly PaginationState pagination55 = new PaginationState { ItemsPerPage = 10 };

    private DateTime? StartDateTime20 { get; set; } = DateTime.Today.AddMonths(-3);
    private DateTime? EndDateTime20 { get; set; } = DateTime.Today;

    private DateTime? StartDateTime55 { get; set; } = DateTime.Today.AddMonths(-3);
    private DateTime? EndDateTime55 { get; set; } = DateTime.Today;

    private bool IsLoading20 { get; set; }
    private bool IsLoading55 { get; set; }

    string? activeid = "tab-1";
    FluentTab? changedto;

    private bool IsDateDisabled(DateTime date)
    {
        return date.Date > DateTime.Today || date.Date < StartDateTime20; // Wyłącza wszystkie daty po dzisiejszym dniu i przed StartDateTime20
    }
    private bool IsAfterEndDate(DateTime date)
    {
        return date.Date > EndDateTime20; // Wyłącza wszystkie daty po EndDate
    }

    string nameFilter = string.Empty;

    private readonly List<FilterColumn<Bnp20Vm>> filterColumns = new List<FilterColumn<Bnp20Vm>>
    {
        new FilterColumn<Bnp20Vm> {FirstRow = true, Label = "Txid", Property = c => c.Txid, IsVisible = true, Width= "200px"},
        new FilterColumn<Bnp20Vm> {FirstRow = true, Label = "Cdtdbtind", Property = c => c.Cdtdbtind, IsVisible = true, Width= "100px"},
        new FilterColumn<Bnp20Vm> {FirstRow = true, Label = "Waluta", Property = c => c.Waluta, IsVisible = true, Width= "100px"},
        new FilterColumn<Bnp20Vm> {FirstRow = true, Label = "Data", Property = c => c.Data.ToString(), IsVisible = true, Width= "200px", IsDefaultSortColumn = true, InitialSortDirection = SortDirection.Descending},
        //new FilterColumn<Bnp20Vm> {FirstRow = true, Label = "Amount", Property = c => c.Kwota, IsVisible = true, Width= "200px"},
        new FilterColumn<Bnp20Vm> {FirstRow = true, Label = "Nazwa", Property = c => c.Nazwa, IsVisible = true, Width= "200px"},
        new FilterColumn<Bnp20Vm> {FirstRow = true, Label = "Adres", Property = c => c.Adres, IsVisible = true, Width= "200px"},
        new FilterColumn<Bnp20Vm> {FirstRow = true, Label = "Panstwo", Property = c => c.Panstwo, IsVisible = true, Width= "100px"},
        new FilterColumn<Bnp20Vm> {FirstRow = true, Label = "Iban", Property = c => c.Iban, IsVisible = true, Width= "200px"},
        new FilterColumn<Bnp20Vm> {FirstRow = true, Label = "Tytul", Property = c => c.Tytul, IsVisible = true, Width= "200px"},
    };

    private readonly List<FilterColumn<Bnp55Vm>> filterColumns55 = new List<FilterColumn<Bnp55Vm>>
    {
        new FilterColumn<Bnp55Vm> {FirstRow = true, Label = "Txid", Property = c => c.Txid, IsVisible = true, Width= "200px"},
        new FilterColumn<Bnp55Vm> {FirstRow = true, Label = "Cdtdbtind", Property = c => c.Cdtdbtind, IsVisible = true, Width= "100px"},
        new FilterColumn<Bnp55Vm> {FirstRow = true, Label = "Waluta", Property = c => c.Waluta, IsVisible = true, Width= "100px"},
        new FilterColumn<Bnp55Vm> {FirstRow = true, Label = "Data", Property = c => c.Data.ToString(), IsVisible = true, Width= "200px", IsDefaultSortColumn = true, InitialSortDirection = SortDirection.Descending},
        //new FilterColumn<Bnp55Vm> {FirstRow = true, Label = "Amount", Property = c => c.Kwota, IsVisible = true, Width= "200px"},
        new FilterColumn<Bnp55Vm> {FirstRow = true, Label = "Nazwa", Property = c => c.Nazwa, IsVisible = true, Width= "200px"},
        new FilterColumn<Bnp55Vm> {FirstRow = true, Label = "Adres", Property = c => c.Adres, IsVisible = true, Width= "200px"},
        new FilterColumn<Bnp55Vm> {FirstRow = true, Label = "Panstwo", Property = c => c.Panstwo, IsVisible = true, Width= "100px"},
        new FilterColumn<Bnp55Vm> {FirstRow = true, Label = "Iban", Property = c => c.Iban, IsVisible = true, Width= "200px"},
        new FilterColumn<Bnp55Vm> {FirstRow = true, Label = "Tytul", Property = c => c.Tytul, IsVisible = true, Width= "200px"},
    };

    private static Expression<Func<Bnp20Vm, string>> GetPropertyExpression(Func<Bnp20Vm, string> propertyFunc)
    {
        return x => propertyFunc(x);
    }

    private static Expression<Func<Bnp55Vm, string>> GetPropertyExpression55(Func<Bnp55Vm, string> propertyFunc)
    {
        return x => propertyFunc(x);
    }

    private void HandleFilterDebounced(FilterColumn<Bnp20Vm> column, ChangeEventArgs args)
    {
        debounceDispatcher.Debounce(500, _ =>
        {
            column.Filter = args.Value.ToString();
            InvokeAsync(StateHasChanged);
        });
    }

    private void HandleFilterDebounced55(FilterColumn<Bnp55Vm> column, ChangeEventArgs args)
    {
        debounceDispatcher.Debounce(500, _ =>
        {
            column.Filter = args.Value.ToString();
            InvokeAsync(StateHasChanged);
        });
    }

    private void HandleClear()
    {
        if (string.IsNullOrWhiteSpace(nameFilter))
        {
            nameFilter = string.Empty;
        }
    }

    private void HandleOnTabChange(FluentTab tab)
    { 
        changedto = tab;
    }

    private static DateOnly ConvertToDateOnly(DateTime? dateTime)
    {
        return dateTime.HasValue ? DateOnly.FromDateTime(dateTime.Value) : DateOnly.MinValue;
    }

    private async Task OnDateChanged(string type, string identifier, DateTime? newDate)
    {
        switch ((type, identifier))
        {
            case ("Start", "tab-1"):
                StartDateTime20 = newDate;
                break;
            case ("Start", "tab-2"):
                StartDateTime55 = newDate;
                break;
            case ("End", "tab-1"):
                EndDateTime20 = newDate;
                break;
            case ("End", "tab-2"):
                EndDateTime55 = newDate;
                break;
            default:
                throw new ArgumentException($"Nieobsługiwane wartości: {type}, {identifier}");
        }
        await LoadBnp(identifier);
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }
    
    private async Task Load()
    {
        bnp20 = await _mediator.Send(new GetAllBnp20Query(ConvertToDateOnly(StartDateTime20), ConvertToDateOnly(EndDateTime20)));
        bnp55 = await _mediator.Send(new GetAllBnp55Query(ConvertToDateOnly(StartDateTime55), ConvertToDateOnly(EndDateTime55)));
    }

    private async Task LoadBnp(string identifier)
    {
        StateHasChanged();
        ToastIntent intent;
        string message = string.Empty;
        try
        {
            if (identifier == "tab-1")
            {
                IsLoading20 = true;
                Console.WriteLine("Load Bnp20");
                intent = ToastIntent.Progress;
                message = "Data is loading!";
                _toastService.ShowToast(intent, message, 3000);
                bnp20 = await _mediator.Send(new GetAllBnp20Query(ConvertToDateOnly(StartDateTime20), ConvertToDateOnly(EndDateTime20)));
            }
            else
            {
                IsLoading55 = true;
                Console.WriteLine("Load Bnp55");
                intent = ToastIntent.Progress;
                message = "Data is loading!";
                _toastService.ShowToast(intent, message, 3000);
                bnp55 = await _mediator.Send(new GetAllBnp55Query(ConvertToDateOnly(StartDateTime55), ConvertToDateOnly(EndDateTime55)));
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            intent = ToastIntent.Error;
            message = "Error loading data!";
        }
        finally
        {
            IsLoading20 = false;
            IsLoading55 = false;
            intent = ToastIntent.Success;
            message = "Data has been loading properly!";
            StateHasChanged();
        }
        _toastService.ShowToast(intent, message, 3000);
     }
}