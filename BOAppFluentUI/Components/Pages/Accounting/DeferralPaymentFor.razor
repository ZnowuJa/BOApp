    // {
    //     var rolesOut = new List<OrganisationRoleForFormVm>();
    //     var manager = await _mediator.Send(new GetEmployeeByEnovaIdQuery(emp.ManagerId));
    //     OrganisationRoleForFormVm managerRole = new()
    //     {
    //             IsDefault = true,
    //             EmpId = emp.ManagerId,
    //             LongName = manager.LongName
    //     };
