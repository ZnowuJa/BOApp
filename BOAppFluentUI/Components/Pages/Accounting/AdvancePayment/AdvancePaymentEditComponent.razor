    private async Task GetAllowedPersons()
    {
        if (formItem.Status == "Rejestracja")
        {
            allowedEmp.Add(_userContext.EnovaEmpId);
            allowedEditor.Add(_userContext.EnovaEmpId);
        }
        if (stal1 || stal2)
