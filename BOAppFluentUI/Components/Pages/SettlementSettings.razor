@page "/settlementsettings"
@inject NavigationManager _navMan

<h3>SettlementSettings</h3>

<FluentGrid Justify="@Justification">
        <FluentGridItem xs="@xssize" sm="@smsize">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical"
                         HorizontalAlignment="HorizontalAlignment.Center"
                         VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.MoneyCalculator())" />
                <h4>CostCenters</h4>

                <FluentButton BackgroundColor="var(--accent-fill-rest)"
                              Color="var(--neutral-fill-rest)"
                              OnClick="@(()=>_navMan.NavigateTo("/costcenters"))">
                    CostCenters
                </FluentButton>
            </FluentStack>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="@xssize" sm="@smsize">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical"
                         HorizontalAlignment="HorizontalAlignment.Center"
                         VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.Globe())" />
                <h4>Countries</h4>

                <FluentButton BackgroundColor="var(--accent-fill-rest)"
                              Color="var(--neutral-fill-rest)"
                              OnClick="@(()=>_navMan.NavigateTo("/countries"))">
                    Countries
                </FluentButton>
            </FluentStack>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="@xssize" sm="@smsize">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical"
                         HorizontalAlignment="HorizontalAlignment.Center"
                         VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.PersonAccounts())" />
                <h4>GLAccounts</h4>

                <FluentButton BackgroundColor="var(--accent-fill-rest)"
                              Color="var(--neutral-fill-rest)"
                              OnClick="@(()=>_navMan.NavigateTo("/glaccounts"))">
                    GLAccounts
                </FluentButton>
            </FluentStack>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="@xssize" sm="@smsize">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical"
                         HorizontalAlignment="HorizontalAlignment.Center"
                         VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.DocumentMultiplePercent())" />
                <h4>VATRates</h4>

                <FluentButton BackgroundColor="var(--accent-fill-rest)"
                              Color="var(--neutral-fill-rest)"
                              OnClick="@(()=>_navMan.NavigateTo("/vatrates"))">
                    VATRates
                </FluentButton>
            </FluentStack>
        </FluentCard>
    </FluentGridItem>
</FluentGrid>
@code {
    JustifyContent Justification = JustifyContent.Center;

    public int xssize { get; set; } = 2;
    public int smsize { get; set; } = 2;
}
