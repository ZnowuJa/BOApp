    private async Task Generate()
    {
        ToastIntent intent;
        string message = string.Empty;
        var dialog = await _dialogService.ShowDialogAsync<AddOnboardingsTimeSpan>(new DialogParameters()
            {
                Height = "450px",
                Width = "400px",
                Title =  "Generuj Onboardingi",
                PreventDismissOnOverlayClick = true,
                PreventScroll = false
            });

        var result = await dialog.Result;

        if (!result.Cancelled)
        {
           
                intent = ToastIntent.Success;
                message = "Organisation has been updated!";
            
        }
        else if (result.Cancelled)
        {
            intent = ToastIntent.Info;
            message = "Operation Cancelled...";
        }
        else
        {
            intent = ToastIntent.Error;
            message = "Something went wrong!";
        }

    }

    private async Task Assign()
    {
        // AdHoc job = new AdHoc(_mediator);
        MarkEmpCoCGroupByJobCodeAdHocJob job = new MarkEmpCoCGroupByJobCodeAdHocJob(_mediator);
        job.Execute();
    }
