                    </FluentNavGroup>
                    

                    <FluentNavGroup OnClick="OnClick" Title="Another Area" Icon="@(new Icons.Regular.Size20.EarthLeaf())">
                        <ChildContent>

                            <FluentNavLink Href="https://sharepoint" Icon="@(new Icons.Regular.Size20.LeafOne())">
                                Another Link 1
                            </FluentNavLink>
                            <FluentNavLink Href="https://sharepoint" Icon="@(new Icons.Regular.Size20.LeafTwo())">
                                Another Link 2
                            </FluentNavLink>
                            
                        </ChildContent>
                    </FluentNavGroup>
                    
                </ChildContent>
            </FluentNavGroup>
            <FluentNavGroup OnClick="OnClick" Title="Empty Slot for future" Icon="@(new Icons.Regular.Size20.EarthLeaf())">
                <ChildContent>


                    <FluentNavGroup OnClick="OnClick" Title="Some Area" Icon="@(new Icons.Regular.Size20.EarthLeaf())">
                        <ChildContent>

                            <FluentNavLink Href="https://sharepoint" Icon="@(new Icons.Regular.Size20.Classification())">
                                Link 1
                            </FluentNavLink>
                            <FluentNavLink Href="https://sharepoint" Icon="@(new Icons.Regular.Size20.Classification())">
                                Link 2
                            </FluentNavLink>
                            <FluentNavLink Href="https://sharepoint" Icon="@(new Icons.Regular.Size20.BuildingFactory())">
                                Link 3
                            </FluentNavLink>

                        </ChildContent>
                    </FluentNavGroup>


                    <FluentNavGroup OnClick="OnClick" Title="Another Area" Icon="@(new Icons.Regular.Size20.EarthLeaf())">
                        <ChildContent>

                            <FluentNavLink Href="https://sharepoint" Icon="@(new Icons.Regular.Size20.LeafOne())">
                                Another Link 1
                            </FluentNavLink>
                            <FluentNavLink Href="https://sharepoint" Icon="@(new Icons.Regular.Size20.LeafTwo())">
                                Another Link 2
                            </FluentNavLink>

                        </ChildContent>
                    </FluentNavGroup>

                </ChildContent>
            </FluentNavGroup> *@
        </FluentNavMenu>
    </nav>
</div>

@code {
    private bool expanded = true;
    private string envi { get; set; } = string.Empty;
    private string appVersion { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        envi = _configuration["Environment"];
        appVersion = _configuration["AppVersion"];
    }
    void OnClick(MouseEventArgs e)
    {
        Console.WriteLine("NavMenu item clicked");
    }
}

